    {
      "name": "Carta individual por franquicia",
      "item": [
        {
          "name": "Buscar carta individual (Pokemon)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const data = pm.response.json();",
                  "const query = (pm.collectionVariables.get('cardNamePokemon') || '').toLowerCase();",
                  "const matches = (data?.products || []).filter(p => (p?.name || '').toLowerCase().includes(query) || (p?.clean_name || '').toLowerCase().includes(query));",
                  "const compact = matches.map(m => ({ id: m.id, name: m.name, number: m.number, rarity: m.rarity, image_url: m.image_url }));",
                  "pm.collectionVariables.set('matchesPokemon', JSON.stringify(compact));",
                  "pm.test('Coincidencias encontradas', function () {",
                  "  pm.expect(matches.length).to.be.above(0);",
                  "});",
                  "pm.visualizer.set(`",
                  "<style>body{font-family:Inter,Arial,sans-serif;padding:12px}table{border-collapse:collapse;width:100%}th,td{border:1px solid #ddd;padding:8px;text-align:left}th{background:#f5f5f5}</style>",
                  "<h3>Coincidencias Pokemon ({{count}})</h3>",
                  "<table><thead><tr><th>ID</th><th>Nombre</th><th>Numero</th><th>Rarity</th></tr></thead><tbody>{{#each items}}<tr><td>{{id}}</td><td>{{name}}</td><td>{{number}}</td><td>{{rarity}}</td></tr>{{/each}}</tbody></table>",
                  "`, { count: compact.length, items: compact });",
                  "console.log('matchesPokemon:', compact);"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/{{catPokemon}}/sets/{{setIdPokemon}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "{{catPokemon}}",
                "sets",
                "{{setIdPokemon}}"
              ]
            },
            "description": "Trae el set y filtra por nombre de carta en el script de Postman. Resultado guardado en matchesPokemon."
          },
          "response": []
        },
